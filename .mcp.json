{
  "mcpServers": {
    "browsercode-knowledge": {
      "command": "bun",
      "args": ["run", "harness/mcp-server.ts"]
    },
    "bilibili-readonly": {
      "command": "tools/mcp/.venv/Scripts/python.exe",
      "args": ["tools/mcp/bilibili-readonly-server.py"]
    },
    "bilibili-video-info": {
      "command": "tools/mcp/.venv/Scripts/bilibili-video-info-mcp.exe",
      "env": {
        "SESSDATA": "${SESSDATA}"
      }
    },
    "douyin-cli": {
      "command": "tools/mcp/bin/douyin.exe",
      "args": ["mcp"],
      "env": {
        "HTTP_PROXY": "",
        "HTTPS_PROXY": "",
        "ALL_PROXY": "",
        "NO_PROXY": "*"
      }
    },
    "xhs-local": {
      "command": "tools/mcp/.venv/Scripts/uvx.exe",
      "args": ["--from", "jobson-xhs-mcp", "xhs-mcp"],
      "env": {
        "XHS_COOKIE": "${XHS_COOKIE}"
      },
      "disabled": true
    }
  }
}
