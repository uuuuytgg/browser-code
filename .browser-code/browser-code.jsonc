{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "browsercode-knowledge": {
      "type": "local",
      "command": ["bun", "run", "harness/mcp-server.ts"],
      "cwd": ".",
      "enabled": true,
    },
    "bilibili-readonly": {
      "type": "local",
      "command": ["tools/mcp/.venv/Scripts/python.exe", "tools/mcp/bilibili-readonly-server.py"],
      "cwd": ".",
      "enabled": true,
    },
    "bilibili-video-info": {
      "type": "local",
      "command": ["tools/mcp/.venv/Scripts/bilibili-video-info-mcp.exe"],
      "cwd": ".",
      "environment": {
        "SESSDATA": "{env:SESSDATA}",
      },
      "enabled": true,
    },
    "socialdatax-xhs": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx -y mcp-remote https://mcp.52choujiang.com/xhs/mcp --header \"Authorization: Bearer %SOCIALDATAX_API_KEY%\""
      ],
      "cwd": ".",
      "enabled": false,
    },
    "xhs-local": {
      "type": "local",
      "command": ["tools/mcp/.venv/Scripts/uvx.exe", "--from", "jobson-xhs-mcp", "xhs-mcp"],
      "cwd": ".",
      "environment": {
        "XHS_COOKIE": "{env:XHS_COOKIE}",
      },
      "enabled": true,
    },
    "douyin-cli": {
      "type": "local",
      "command": ["tools/mcp/bin/douyin.exe", "mcp"],
      "cwd": ".",
      "environment": {
        "HTTP_PROXY": "",
        "HTTPS_PROXY": "",
        "ALL_PROXY": "",
        "NO_PROXY": "*",
      },
      "enabled": true,
    },
    "socialdatax-douyin": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx -y @smithery/cli run ychen20141229/douyin-insights --key %SOCIALDATAX_API_KEY%"
      ],
      "cwd": ".",
      "enabled": false,
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp"],
      "cwd": ".",
      "enabled": true,
    },
  },
  // Override model context limit so 1M models aren't incorrectly
  // squeezed by the API-returned max_context_window_tokens.
  // The usable() threshold in overflow.ts subtracts buffer + output from this.
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-v4-flash": {
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        }
      }
    }
  },
  // ProReader subagent — research expert with independent context.
  // Spawned by the main agent via task({subagent_type: "proreader", ...}).
  "agent": {
    "proreader": {
      "mode": "subagent",
      "description": "Browser Code research expert. Receives research tasks, generates plans via the proreader tool, executes searches across 12 providers, spawns worker subagents for parallel batch work, synthesizes results. Returns structured findings — does NOT write vault/kb/sqlite.",
      "model": {
        "modelID": "deepseek-v4-flash",
        "providerID": "deepseek"
      },
      "permission": {
        "proreader": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "read": "allow",
        "bash": "allow",
        "task": "allow",
        "question": "deny",
        "todowrite": "deny",
        "write": "deny",
        "edit": "deny",
        "save_markdown_note": "deny",
        "kb_manage": "deny",
        "search_vault": "deny"
      },
      "steps": 25
    }
  }
}
