{
  "githubCli": {
    "enabled": true,
    "server": "local-cli",
    "source": "github:cli/cli",
    "purpose": "github_discovery_and_source_research",
    "requiresEnv": ["GITHUB_TOKEN", "GH_TOKEN"],
    "notes": [
      "Global GitHub CLI backend for ProReader GitHub provider.",
      "Used for fuzzy repository, issue, pull request, release, and code discovery after ProReader selects GitHub.",
      "Direct GitHub URLs still stay on the existing BrowserCode URL pipeline."
    ],
    "tools": {
      "searchRepos": "gh search repos",
      "searchIssues": "gh search issues",
      "searchPrs": "gh search prs",
      "searchCode": "gh search code"
    }
  },
  "youtubeTranscript": {
    "enabled": true,
    "server": "youtube-transcript",
    "tools": {
      "getTranscript": "get_transcript",
      "getTimedTranscript": "get_timed_transcript",
      "getVideoInfo": "get_video_info",
      "getAvailableLanguages": "get_available_languages"
    }
  },
  "bilibiliSearch": {
    "enabled": true,
    "server": "bilibili-readonly",
    "source": "github:adoresever/bilibili-mcp",
    "purpose": "discovery",
    "readonlyTools": [
      "bili_search",
      "bili_comments",
      "bili_subtitle",
      "bili_danmaku",
      "bili_video_info",
      "bili_crawl",
      "bili_hot_videos",
      "bili_hot_buzzwords",
      "bili_weekly_hot",
      "bili_rank",
      "bili_user_info",
      "bili_user_videos",
      "bili_favorite_lists",
      "bili_favorite_content"
    ],
    "disabledWriteTools": [
      "bili_reply",
      "bili_send_dynamic",
      "bili_upload_video",
      "bili_upload_video_multi",
      "bili_send_opus",
      "bili_send_message"
    ],
    "tools": {
      "search": "bili_search",
      "videoInfo": "bili_video_info",
      "subtitle": "bili_subtitle",
      "danmaku": "bili_danmaku",
      "comments": "bili_comments",
      "hotVideos": "bili_hot_videos",
      "hotBuzzwords": "bili_hot_buzzwords",
      "rank": "bili_rank"
    }
  },
  "bilibiliVideoInfo": {
    "enabled": true,
    "server": "bilibili-video-info",
    "source": "github:lesir831/bilibili-video-info-mcp",
    "purpose": "approved_enrichment",
    "requiresEnv": ["SESSDATA"],
    "tools": {
      "getSubtitle": "get_subtitles",
      "getDanmaku": "get_danmaku",
      "getComments": "get_comments"
    }
  },
  "douyinMcp": {
    "enabled": true,
    "server": "douyin-cli",
    "source": "github:tamnd/douyin-cli",
    "purpose": "discovery_and_approved_enrichment",
    "notes": [
      "Preferred over SocialDataX by default. Uses public Douyin web surfaces; hot search is most reliable.",
      "search/video/comments may require China/residential session or warm browser session because of Douyin anti-bot."
    ],
    "tools": {
      "workSearch": "search",
      "workDetail": "video",
      "comments": "comments",
      "creatorProfile": "user",
      "creatorWorks": "posts",
      "hotSearch": "hot"
    }
  },
  "xiaohongshuMcp": {
    "enabled": true,
    "server": "xhs-local",
    "source": "github:jobsonlook/xhs-mcp",
    "purpose": "discovery_and_approved_enrichment",
    "requiresEnv": ["XHS_COOKIE"],
    "readonlyTools": [
      "check_cookie",
      "home_feed",
      "search_notes",
      "get_note_content",
      "get_note_comments"
    ],
    "disabledWriteTools": ["post_comment"],
    "tools": {
      "noteSearch": "search_notes",
      "homeFeed": "home_feed",
      "noteDetailByUrl": "get_note_content",
      "commentsByUrl": "get_note_comments",
      "checkCookie": "check_cookie"
    }
  },
  "socialdataxDouyinMcp": {
    "enabled": false,
    "server": "socialdatax-douyin",
    "source": "smithery:ychen20141229/douyin-insights",
    "purpose": "expensive_fallback_only_enable_on_explicit_request",
    "requiresEnv": ["SOCIALDATAX_API_KEY"],
    "tools": {
      "workSearch": "work_search",
      "workDetail": "work_detail",
      "comments": "get_comments",
      "commentReplies": "get_comment_replies",
      "creatorProfile": "creator_profile",
      "creatorWorks": "creator_works",
      "hotSearch": "hot_search"
    }
  },
  "socialdataxXhsMcp": {
    "enabled": false,
    "server": "socialdatax-xhs",
    "source": "github:devinchen2014/xiaohongshu-xhs-rednote-mcp",
    "purpose": "expensive_fallback_only_enable_on_explicit_request",
    "transport": "streamable-http",
    "url": "https://mcp.52choujiang.com/xhs/mcp",
    "requiresEnv": ["SOCIALDATAX_API_KEY"],
    "tools": {
      "noteSearch": "xhs_search_notes",
      "hotList": "xhs_get_search_hot_list",
      "noteDetailByUrl": "xhs_get_note_detail_by_note_url",
      "noteDetail": "xhs_get_note_detail_by_note_id",
      "comments": "xhs_get_note_comments_by_note_id",
      "commentsByUrl": "xhs_get_note_comments_by_note_url",
      "subComments": "xhs_get_note_sub_comments_by_comment_id",
      "creatorProfile": "xhs_get_user_info_by_user_id",
      "creatorProfileByUrl": "xhs_get_user_info_by_profile_url",
      "creatorNotes": "xhs_get_user_posted_notes_by_user_id",
      "creatorNotesByUrl": "xhs_get_user_posted_notes_by_profile_url"
    }
  },
  "tiktokMcp": {
    "enabled": false,
    "server": "tiktok",
    "tools": {
      "videoSearch": "video_search",
      "videoDetail": "video_detail",
      "comments": "get_comments"
    }
  }
}
