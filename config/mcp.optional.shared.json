{
  "mcpServers": {
    "douyin-cli": {
      "command": "tools/mcp/bin/douyin.exe",
      "args": ["mcp"]
    },
    "xhs-local": {
      "command": "tools/mcp/.venv/Scripts/uvx.exe",
      "args": ["--from", "jobson-xhs-mcp", "xhs-mcp"],
      "env": {
        "XHS_COOKIE": "${XHS_COOKIE}"
      }
    },
    "bilibili-video-info": {
      "command": "tools/mcp/.venv/Scripts/bilibili-video-info-mcp.exe",
      "env": {
        "SESSDATA": "${SESSDATA}"
      }
    },
    "socialdatax-xhs": {
      "purpose": "expensive_fallback_only_enable_on_explicit_request",
      "command": "cmd",
      "args": [
        "/c",
        "npx -y mcp-remote https://mcp.52choujiang.com/xhs/mcp --header \"Authorization: Bearer %SOCIALDATAX_API_KEY%\""
      ]
    },
    "socialdatax-douyin": {
      "purpose": "expensive_fallback_only_enable_on_explicit_request",
      "command": "cmd",
      "args": [
        "/c",
        "npx -y @smithery/cli run ychen20141229/douyin-insights --key %SOCIALDATAX_API_KEY%"
      ]
    }
  }
}
