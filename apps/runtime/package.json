{
  "name": "@ska/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ska/schemas": "workspace:*",
    "@ska/shared": "workspace:*",
    "@ska/tool-resource": "workspace:*",
    "@ska/tool-vault": "workspace:*",
    "@ska/tool-video": "workspace:*",
    "@ska/tool-web": "workspace:*",
    "zod": "^4.0.5"
  }
}
